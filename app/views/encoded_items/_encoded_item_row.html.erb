<tr id="<%= dom_id(encoded_item) %>">
  <td><%= encoded_item.descriptor %></td>
  <td><%= encoded_item.value %></td>
  <td>
    <span id="decoded_item_<%= encoded_item.id %>" class="hidden_encoded_value">
      ?
    </span>
  </td>
  <td>
    <button class="icon-button toggle-btn" id="toggle-btn-<%= encoded_item.id %>" onclick="toggleEncodedItemValueDisplay(<%= encoded_item.id %>)" title="Toggle visibility" data-visible="false">
      <i class="fas fa-eye"></i>
    </button>
    <% unless encoded_item.is_item_with_main_descriptor? %>
      <button class="icon-button" onclick="showDeleteItemDialogWithItemId(<%= encoded_item.id %>)" title="Delete item">
        <i class="fas fa-trash"></i>
      </button>
    <% end %>
  </td>
</tr>